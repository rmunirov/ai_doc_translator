# LLM provider: gigachat | lm_studio
LLM_PROVIDER=gigachat

# GigaChat
GIGACHAT_API_KEY=your_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Pro

# LM Studio (local) — start server in Developer tab, default port 1234
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local

# LLM HTTP request timeout (seconds) — increase for large chunks
LLM_REQUEST_TIMEOUT=600

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_doc_translator
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_doc_translator

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# File storage
UPLOAD_DIR=./uploads
RESULT_DIR=./results
MAX_FILE_SIZE_MB=50

# Async task queue
QUEUE_WORKERS=2

# Chunking
CHUNK_MAX_TOKENS_PDF=1200
CHUNK_MIN_TOKENS=400

# Context update — skip LLM if chunk < N tokens
CONTEXT_UPDATE_MIN_TOKENS=300
CONTEXT_UPDATE_TIMEOUT_SEC=90
CONTEXT_UPDATE_MAX_CHARS=12000

# Job progress — DB write every N chunks (1 = every chunk)
PROGRESS_UPDATE_BATCH_SIZE=3

# LangSmith (tracing for LangChain/LangGraph)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_key_here
