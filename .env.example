# LLM
GIGACHAT_API_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Local LLM (optional)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=mistral

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_doc_translator

# Storage
UPLOAD_DIR=./uploads
RESULT_DIR=./results

# Misc
MAX_FILE_SIZE_MB=10
DEFAULT_TARGET_LANG=ru
